# ============================================================
# contracts/.env.example
# 실제 .env 파일을 복사하여 사용하세요: cp .env.example .env
# .env 파일은 절대 git에 커밋하지 마세요.
# ============================================================

# Alchemy Sepolia RPC URL
# https://dashboard.alchemy.com 에서 앱 생성 후 발급
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# 배포용 지갑 개인키 (0x 접두어 제외)
# 반드시 테스트 전용 지갑만 사용하세요. 실제 자산이 있는 지갑 사용 금지.
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_without_0x_prefix

# Etherscan API Key (소스코드 검증용)
# https://etherscan.io/myapikey 에서 발급
ETHERSCAN_API_KEY=your_etherscan_api_key

# 가스비 리포트 활성화 여부 (true / false)
REPORT_GAS=false
