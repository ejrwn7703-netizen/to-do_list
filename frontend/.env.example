# ============================================================
# frontend/.env.example
# 실제 .env 파일을 복사하여 사용하세요: cp .env.example .env
# .env 파일은 절대 git에 커밋하지 마세요.
# Vite에서 환경 변수는 반드시 VITE_ 접두어가 필요합니다.
# ============================================================

# Sepolia에 배포된 TodoList 컨트랙트 주소 (Phase 3 배포 후 입력)
VITE_CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Alchemy Sepolia RPC URL (공개 RPC는 rate limit이 있으므로 자체 키 사용 권장)
VITE_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Sepolia Etherscan 기본 URL (트랜잭션 링크 생성용, 변경 불필요)
VITE_ETHERSCAN_URL=https://sepolia.etherscan.io

# Sepolia 체인 ID (변경 불필요)
VITE_SEPOLIA_CHAIN_ID=11155111
